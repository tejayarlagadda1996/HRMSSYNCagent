<Window x:Class="HRMSSyncManager.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:HRMSSyncManager.Views"
        xmlns:converters="clr-namespace:HRMSSyncManager.Converters"
        Title="HRMS Attendance Sync Manager"
        Height="720"
        Width="980"
        MinHeight="600"
        MinWidth="800"
        Background="{StaticResource BackgroundBrush}"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibility"/>
        <converters:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibility"/>
    </Window.Resources>

    <Grid Margin="24">
        <views:SetupWizardView DataContext="{Binding SetupWizard}"
                               Visibility="{Binding ShowSetupWizard, Converter={StaticResource BoolToVisibility}}"/>
        <views:DashboardView DataContext="{Binding Dashboard}"
                             Visibility="{Binding ShowDashboard, Converter={StaticResource BoolToVisibility}}"/>
    </Grid>
</Window>
