<UserControl x:Class="HRMSSyncManager.Views.SetupWizardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:HRMSSyncManager.Converters">
    <UserControl.Resources>
        <converters:InverseBoolConverter x:Key="InverseBool"/>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,24">
            <TextBlock Text="HRMS Attendance Sync Setup"
                       FontSize="28"
                       FontWeight="Bold"
                       Foreground="{StaticResource TextBrush}"/>
            <TextBlock Text="Configure the sync agent for your organization"
                       Foreground="{StaticResource MutedTextBrush}"
                       Margin="0,4,0,0"/>
            <TextBlock Margin="0,16,0,0"
                       Foreground="{StaticResource PrimaryBrush}"
                       FontWeight="SemiBold"
                       Text="{Binding CurrentStep, StringFormat=Step {0} of 5}"/>
        </StackPanel>

        <Border Grid.Row="1" Style="{StaticResource CardBorder}">
            <Grid>
                <!-- Step 1: Company -->
                <StackPanel>
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding CurrentStep}" Value="1">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>
                    <TextBlock Text="Company Information" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,16"/>
                    <TextBlock Text="Company Name" Style="{StaticResource FieldLabel}"/>
                    <TextBox Text="{Binding CompanyName, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FieldTextBox}"/>
                    <TextBlock Text="Company Code" Style="{StaticResource FieldLabel}"/>
                    <TextBox Text="{Binding CompanyCode, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FieldTextBox}"/>
                </StackPanel>

                <!-- Step 2: API -->
                <StackPanel>
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding CurrentStep}" Value="2">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>
                    <TextBlock Text="Cloud API" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,16"/>
                    <TextBlock Text="API Sync URL (full endpoint)" Style="{StaticResource FieldLabel}"/>
                    <TextBox Text="{Binding ApiUrl, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FieldTextBox}"/>
                    <TextBlock Text="Example: https://api.myhrms.com/api/attendance/sync"
                               Foreground="{StaticResource MutedTextBrush}"
                               FontSize="12"
                               Margin="0,-8,0,12"/>
                    <TextBlock Text="API Key" Style="{StaticResource FieldLabel}"/>
                    <TextBox Text="{Binding ApiKey, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FieldTextBox}"/>
                    <Button Content="Test API Connection"
                            Command="{Binding TestApiConnectionCommand}"
                            Style="{StaticResource SecondaryButton}"
                            HorizontalAlignment="Left"/>
                </StackPanel>

                <!-- Step 3: SQL -->
                <StackPanel>
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding CurrentStep}" Value="3">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>
                    <TextBlock Text="SQL Server Configuration" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,16"/>
                    <TextBlock Text="SQL Instance" Style="{StaticResource FieldLabel}"/>
                    <ComboBox ItemsSource="{Binding SqlInstances}"
                              Text="{Binding SqlServer, UpdateSourceTrigger=PropertyChanged}"
                              IsEditable="True"
                              Margin="0,0,0,12"
                              Padding="8,6"/>
                    <Button Content="Detect SQL Instances"
                            Command="{Binding DetectSqlInstancesCommand}"
                            Style="{StaticResource SecondaryButton}"
                            HorizontalAlignment="Left"
                            Margin="0,0,0,12"/>
                    <TextBlock Text="Database Name" Style="{StaticResource FieldLabel}"/>
                    <TextBox Text="{Binding Database, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FieldTextBox}"/>
                    <TextBlock Text="Username (leave empty for Windows Auth)" Style="{StaticResource FieldLabel}"/>
                    <TextBox Text="{Binding SqlUsername, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FieldTextBox}"/>
                    <TextBlock Text="Password" Style="{StaticResource FieldLabel}"/>
                    <PasswordBox x:Name="SqlPasswordBox" Style="{StaticResource FieldPasswordBox}" PasswordChanged="OnSqlPasswordChanged"/>
                    <Button Content="Test SQL Connection"
                            Command="{Binding TestSqlConnectionCommand}"
                            Style="{StaticResource SecondaryButton}"
                            HorizontalAlignment="Left"/>
                </StackPanel>

                <!-- Step 4: Sync -->
                <StackPanel>
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding CurrentStep}" Value="4">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>
                    <TextBlock Text="Sync Configuration" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,16"/>
                    <TextBlock Text="Sync Interval (seconds)" Style="{StaticResource FieldLabel}"/>
                    <TextBox Text="{Binding SyncIntervalSeconds, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FieldTextBox}"/>
                    <TextBlock Text="Batch Size" Style="{StaticResource FieldLabel}"/>
                    <TextBox Text="{Binding BatchSize, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FieldTextBox}"/>
                </StackPanel>

                <!-- Step 5: Finish -->
                <StackPanel>
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding CurrentStep}" Value="5">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>
                    <TextBlock Text="Ready to Install" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,16"/>
                    <TextBlock TextWrapping="Wrap" Foreground="{StaticResource MutedTextBrush}" Margin="0,0,0,8"
                               Text="The setup wizard will save your configuration, register HRMSAgent as a Windows service, and start syncing attendance data automatically."/>
                    <TextBlock TextWrapping="Wrap" Margin="0,8,0,0">
                        <Run Text="Company: " FontWeight="SemiBold"/>
                        <Run Text="{Binding CompanyName, Mode=OneWay}"/>
                        <LineBreak/>
                        <Run Text="Code: " FontWeight="SemiBold"/>
                        <Run Text="{Binding CompanyCode, Mode=OneWay}"/>
                        <LineBreak/>
                        <Run Text="SQL: " FontWeight="SemiBold"/>
                        <Run Text="{Binding SqlServer, Mode=OneWay}"/>
                        <LineBreak/>
                        <Run Text="Database: " FontWeight="SemiBold"/>
                        <Run Text="{Binding Database, Mode=OneWay}"/>
                    </TextBlock>
                </StackPanel>
            </Grid>
        </Border>

        <TextBlock Grid.Row="2"
                   Margin="0,8,0,8"
                   Foreground="{StaticResource MutedTextBrush}"
                   Text="{Binding StatusMessage}"
                   TextWrapping="Wrap"/>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Back"
                    Command="{Binding BackCommand}"
                    Style="{StaticResource SecondaryButton}"
                    Margin="0,0,8,0"
                    IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBool}}"/>
            <Button Content="Next"
                    Command="{Binding NextCommand}"
                    Margin="0,0,8,0">
                <Button.Style>
                    <Style TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
                        <Setter Property="Visibility" Value="Visible"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding CurrentStep}" Value="5">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
            <Button Content="Finish &amp; Install"
                    Command="{Binding FinishCommand}">
                <Button.Style>
                    <Style TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding CurrentStep}" Value="5">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
        </StackPanel>
    </Grid>
</UserControl>
