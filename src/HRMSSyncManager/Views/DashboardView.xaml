<UserControl x:Class="HRMSSyncManager.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:HRMSSyncManager.Converters"
             xmlns:models="clr-namespace:HRMSAgent.Core.Models;assembly=HRMSAgent.Core">
    <UserControl.Resources>
        <converters:HealthToBrushConverter x:Key="HealthToBrush"/>
        <converters:HealthLevelToTextConverter x:Key="HealthLevelToText"/>
        <converters:StatusMessageToBrushConverter x:Key="StatusMessageToBrush"/>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibility"/>
        <converters:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibility"/>
        <converters:InverseBoolConverter x:Key="InverseBool"/>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Margin="0,0,0,20">
                <TextBlock Text="HRMS Attendance Sync Manager"
                           FontSize="28"
                           FontWeight="Bold"
                           Foreground="{StaticResource TextBrush}"/>
                <TextBlock Text="Monitor and configure the attendance sync agent"
                           Foreground="{StaticResource MutedTextBrush}"
                           Margin="0,4,0,0"/>
            </StackPanel>

            <Border Grid.Row="1"
                    Background="#FEF3C7"
                    BorderBrush="#F59E0B"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="12"
                    Margin="0,0,0,12"
                    Visibility="{Binding IsServiceNotInstalled, Converter={StaticResource BoolToVisibility}}">
                <TextBlock TextWrapping="Wrap" Foreground="#92400E">
                    <Run FontWeight="SemiBold">Service not installed.</Run>
                    <Run> Your settings are saved. Click </Run>
                    <Run FontWeight="SemiBold">Install Service</Run>
                    <Run> below to enable background sync. (Administrator required — you already have this if you used Run as administrator.)</Run>
                </TextBlock>
            </Border>

            <!-- Status Cards -->
            <UniformGrid Grid.Row="2" Columns="3" Margin="0,0,0,16">
                <Border Style="{StaticResource CardBorder}" Margin="0,0,8,12">
                    <StackPanel>
                        <TextBlock Text="Service Status" Style="{StaticResource FieldLabel}"/>
                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                            <Ellipse Width="12" Height="12" Margin="0,4,8,0"
                                     Fill="{Binding ServiceHealth, Converter={StaticResource HealthToBrush}}"/>
                            <TextBlock Text="{Binding ServiceStatus}" FontSize="18" FontWeight="SemiBold"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource CardBorder}" Margin="4,0,4,12">
                    <StackPanel>
                        <TextBlock Text="API Status" Style="{StaticResource FieldLabel}"/>
                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                            <Ellipse Width="12" Height="12" Margin="0,4,8,0"
                                     Fill="{Binding ApiHealth, Converter={StaticResource HealthToBrush}}"/>
                            <TextBlock Text="{Binding ApiHealth, Converter={StaticResource HealthLevelToText}}" FontSize="18" FontWeight="SemiBold"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource CardBorder}" Margin="8,0,0,12">
                    <StackPanel>
                        <TextBlock Text="SQL Status" Style="{StaticResource FieldLabel}"/>
                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                            <Ellipse Width="12" Height="12" Margin="0,4,8,0"
                                     Fill="{Binding SqlHealth, Converter={StaticResource HealthToBrush}}"/>
                            <TextBlock Text="{Binding SqlHealth, Converter={StaticResource HealthLevelToText}}" FontSize="18" FontWeight="SemiBold"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </UniformGrid>

            <Border Grid.Row="3" Style="{StaticResource CardBorder}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Margin="0,0,12,0">
                        <TextBlock Text="Sync Overview" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,12"/>
                        <TextBlock><Run Text="Last Sync: " FontWeight="SemiBold"/><Run Text="{Binding LastSyncTime, Mode=OneWay}"/></TextBlock>
                        <TextBlock Margin="0,4,0,0"><Run Text="Last Successful Sync: " FontWeight="SemiBold"/><Run Text="{Binding LastSuccessfulSync, Mode=OneWay}"/></TextBlock>
                        <TextBlock Margin="0,4,0,0"><Run Text="Pending Records: " FontWeight="SemiBold"/><Run Text="{Binding PendingRecordsCount, Mode=OneWay}"/></TextBlock>
                        <TextBlock Margin="0,4,0,0"><Run Text="Sync Interval: " FontWeight="SemiBold"/><Run Text="{Binding SyncIntervalSeconds, Mode=OneWay}"/><Run Text=" seconds"/></TextBlock>
                        <TextBlock Margin="0,4,0,0"><Run Text="SQL Instance: " FontWeight="SemiBold"/><Run Text="{Binding SqlServer, Mode=OneWay}"/></TextBlock>
                        <TextBlock Margin="0,4,0,0"><Run Text="Database: " FontWeight="SemiBold"/><Run Text="{Binding Database, Mode=OneWay}"/></TextBlock>
                    </StackPanel>

                    <StackPanel Grid.Column="1">
                        <TextBlock Text="Service Controls" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,12"/>
                        <WrapPanel>
                            <Button Content="Install Service"
                                    Command="{Binding InstallServiceCommand}"
                                    Style="{StaticResource PrimaryButton}"
                                    Margin="0,0,8,8"
                                    Visibility="{Binding IsServiceNotInstalled, Converter={StaticResource BoolToVisibility}}"/>
                            <Button Content="Start Service"
                                    Command="{Binding StartServiceCommand}"
                                    Style="{StaticResource PrimaryButton}"
                                    Margin="0,0,8,8"
                                    Visibility="{Binding ShowStartService, Converter={StaticResource BoolToVisibility}}"/>
                            <Button Content="Pause Service"
                                    Command="{Binding PauseServiceCommand}"
                                    Style="{StaticResource SecondaryButton}"
                                    Margin="0,0,8,8"
                                    Visibility="{Binding ShowPauseService, Converter={StaticResource BoolToVisibility}}"/>
                            <Button Content="Restart Service"
                                    Command="{Binding RestartServiceCommand}"
                                    Style="{StaticResource SecondaryButton}"
                                    Margin="0,0,8,8"
                                    Visibility="{Binding ShowRestartService, Converter={StaticResource BoolToVisibility}}"/>
                            <Button Content="Open Logs Folder" Command="{Binding OpenLogsFolderCommand}" Style="{StaticResource SecondaryButton}" Margin="0,0,8,8"/>
                            <Button Content="Refresh Status" Command="{Binding RefreshStatusCommand}" Style="{StaticResource SecondaryButton}" Margin="0,0,8,8"/>
                        </WrapPanel>
                    </StackPanel>
                </Grid>
            </Border>

            <Border Grid.Row="4" Style="{StaticResource CardBorder}" Margin="0,12,0,0">
                <StackPanel>
                    <TextBlock Text="Configuration" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,12"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Margin="0,0,12,0">
                            <TextBlock Text="Company Name" Style="{StaticResource FieldLabel}"/>
                            <TextBox Text="{Binding CompanyName, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FieldTextBox}"/>
                            <TextBlock Text="Company Code" Style="{StaticResource FieldLabel}"/>
                            <TextBox Text="{Binding CompanyCode, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FieldTextBox}"/>
                            <TextBlock Text="API Sync URL (full endpoint)" Style="{StaticResource FieldLabel}"/>
                            <TextBox Text="{Binding ApiUrl, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FieldTextBox}"/>
                            <TextBlock Text="API Key" Style="{StaticResource FieldLabel}"/>
                            <TextBox Text="{Binding ApiKey, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FieldTextBox}"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1">
                            <TextBlock Text="SQL Server" Style="{StaticResource FieldLabel}"/>
                            <TextBox Text="{Binding SqlServer, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FieldTextBox}"/>
                            <TextBlock Text="Database" Style="{StaticResource FieldLabel}"/>
                            <TextBox Text="{Binding Database, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FieldTextBox}"/>
                            <TextBlock Text="Username" Style="{StaticResource FieldLabel}"/>
                            <TextBox Text="{Binding SqlUsername, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FieldTextBox}"/>
                            <TextBlock Text="Password" Style="{StaticResource FieldLabel}"/>
                            <PasswordBox x:Name="SqlPasswordBox" Style="{StaticResource FieldPasswordBox}" PasswordChanged="OnSqlPasswordChanged"/>
                            <TextBlock Text="Sync Interval (seconds)" Style="{StaticResource FieldLabel}"/>
                            <TextBox Text="{Binding SyncIntervalSeconds, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FieldTextBox}"/>
                            <TextBlock Text="Batch Size" Style="{StaticResource FieldLabel}"/>
                            <TextBox Text="{Binding BatchSize, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FieldTextBox}"/>
                        </StackPanel>
                    </Grid>

                    <WrapPanel Margin="0,8,0,0">
                        <Button Content="Save Configuration" Command="{Binding SaveConfigurationCommand}" Style="{StaticResource PrimaryButton}" Margin="0,0,8,0"/>
                        <Button Content="Test SQL Connection" Command="{Binding TestSqlConnectionCommand}" Style="{StaticResource SecondaryButton}" Margin="0,0,8,0"/>
                        <Button Content="Test API Connection" Command="{Binding TestApiConnectionCommand}" Style="{StaticResource SecondaryButton}"/>
                    </WrapPanel>

                    <TextBlock Margin="0,12,0,0"
                               Foreground="{Binding StatusMessage, Converter={StaticResource StatusMessageToBrush}}"
                               Text="{Binding StatusMessage}"
                               TextWrapping="Wrap"/>
                </StackPanel>
            </Border>
        </Grid>
    </ScrollViewer>
</UserControl>
